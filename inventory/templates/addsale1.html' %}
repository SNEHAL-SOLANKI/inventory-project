{% extends 'base.html' %}
{% load static %}
{% block title %}
AddSale
{% endblock %}
{% block content %}
 <div class="inner-content">

            
        <div class="d-flex justify-content-between mb-4 align-items-center">
            <h4 class="m-0 Dashboard_H">
                <i class="bi bi-cart-plus"></i> Add New Sale
            </h4>
        </div>
                
    <div class="box bg-white p-4 rounded-3 shadow">
    <form method="post" enctype="multipart/form-data" class="">
        {% csrf_token %}
    <!-- Customer Section -->
    <h5 class="mb-3 text-primary">Customer Details</h5>
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Customer 111</label>
            <select class="form-control" name="Customer">
                <option>Select Customer</option>
                {% for customer in customers %}
                <option value="{{ customer.custName }}">{{ customer.custName }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label">Invoice No</label>
            <input type="text" name="Invoiceno" class="form-control">
        </div>
        <div class="col-md-4">
            <label class="form-label">Date</label>
            <input type="date" name="Date" class="form-control">
        </div>
    </div>

    <hr class="my-4">

    <!-- Product Section -->
    <h5 class="mb-3 text-primary">Add Products</h5>
    <div class="table-responsive">
        <table class="table table-bordered" id="productTable" name="ProductTable">
            <thead class="table-light">
                <tr>
                    <th>Product</th>
                    <th width="120">Stock</th>
                    <th width="120">Price</th>
                    <th width="120">Qty</th>
                    <th width="140">Total</th>
                    <th width="80">Remove</th>
                </tr>
            </thead>
            <tbody id="productRows">
                <tr>
                    <td>
                        <select class="form-control" name="Product" id="product">
                            <option>Select Product</option>
                            {% for product in products %}
                            <option value="{{ product.prodName }}">{{ product.prodName }}</option>
                            {% endfor %}
                        </select>
                    </td>
                    <td><input type="number" name="Product[]" class="form-control" value="50" readonly></td>
                    <td><input type="number" name="Price[]" class="form-control price" value="100"></td>
                    <td><input type="number" name="Quantity[]" class="form-control qty" value="1"></td>
                    <td><input type="number" name="Total[]" class="form-control total" value="100" readonly></td>
                    <td class="text-center"><button type="button" class="btn btn-danger btn-sm removeRow">X</button></td>
                </tr>
            </tbody>
        </table>
    </div>

    <button type="button" class="btn btn-sm btn-primary mb-3" id="addRow">+ Add Product</button>

    <hr class="my-4">

    <!-- Summary Section -->
    <h5 class="mb-3 text-primary">Bill Summary</h5>
    <div class="row g-3 justify-content-end">
        <div class="col-md-3">
            <label>Subtotal</label>
            <input type="number" name="Subtotal" id="subtotal" class="form-control">
        </div>
        <div class="col-md-3">
            <label>Discount</label>
            <input type="number" name="Discount" id="discount" class="form-control" value="0">
        </div>
        <div class="col-md-3">
            <label>Tax (5%)</label>
            <input type="number" name="Tax" id="tax" class="form-control">
        </div>
        <div class="col-md-3">
            <label>Grand Total</label>
            <input type="number" name="GrandTotal" id="grandTotal" class="form-control">
        </div>
    </div>

    <hr class="my-4">

    <!-- Payment Section -->
    <h5 class="mb-3 text-primary">Payment</h5>
    <div class="row g-3">
        <div class="col-md-4">
            <label>Payment Mode</label>
            <select class="form-control" name="PaymentMode" id="paymentMode">
                <option>Cash</option>
                <option>UPI</option>
                <option>Card</option>
            </select>
        </div>
        <div class="col-md-4">
            <label>Paid Amount</label>
            <input type="number" name="PaidAmount" id="paidAmount" class="form-control">
        </div>
        {% comment %} <div class="col-md-4">
            <label>Change Return</label>
            <input type="number" name="ChangeReturn" id="changeReturn" class="form-control" readonly>
        </div> {% endcomment %}
    </div>

    <div class="text-end mt-4">
        <button type="submit" class="btn btn-theme">Save Sale</button>
        <a href="{% url 'sales' %}" class="btn btn-secondary">Cancel</a>
    </div>

    </form>                 
    
</div>
</div>
    
 
      <!-----Delete Modal------->

    <div class="modal fade" id="delete">
        <div class="modal-dialog modal-dialog-centered modal-md">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete Record</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center">
                    <h4 class="text-secondary mb-3">Are you sure <br> you want to <span class="text-danger fw-bold">Delete</span> this record ?</h4>
                    <div class="">
                    <button class="btn btn-success btn-sm">Yes,Confirm</button>
                    <button class="btn btn-danger btn-sm" data-bs-dismiss="modal">No,Cancel</button>
                </div>
                </div>
                
            </div>
        </div>
    </div>
{% endblock %}
    <script src="{% static 'JS\bootstrap.bundle.min.js' %}"></script>
    <script src="{% static 'JS\jquery-4.0.0.min.js' %}"></script>
    <script src="https://cdn.canvasjs.com/canvasjs.min.js"></script>

{% block extra_js %}  
    <script>
        $(document).ready(function(){
            $('#toggle-btn').click(function(){
                //alert('Hi')
                $('.sidebar').toggleClass('full')
            })
        })
    </script>
{% endblock %}
</body>
</html>